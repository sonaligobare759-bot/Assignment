    "1o.complete the following:\n",
    "#a)Write a closure make_multiplier(n) that\n",
    "returns a function multiplying its input by n.\n",
    "    \n",
    "Create triple and quintuple using it\n",
    "def make_multiplier(n):\n",
    "    def multiplier(x):\n",
    "        return x * n\n",
    "    return multiplier\n",
    "\n",
    "triple = make_multiplier(3)\n",
    "quintuple = make_multiplier(5)\n",
    "\n",
    "print(triple(10))\n",
    "print(quintuple(10))\n",
    "#b)Write a decorator @timer that prints the execution \n",
    "time of any function it wraps. Apply it to slow_sum(n)\n",
    "which computes the sum of squares from 1 to n.\n",
    "\n",
    "import time\n",
    "\n",
    "def timer(func):\n",
    "    def wrapper(*args, **kwargs):\n",
    "        start = time.time()\n",
    "        result = func(*args, **kwargs)\n",
    "        end = time.time()\n",
    "\n",
    "        print(\"Execution Time:\", end - start)\n",
    "        return result\n",
    "    return wrapper\n",
    "\n",
    "\n",
    "@timer\n",
    "def slow_sum(n):\n",
    "    return sum(i * i for i in range(1, n + 1))\n",
    "\n",
    "print(slow_sum(100000))\n",
    "#c)Write a decorator @validate_positive\n",
    "that raises a ValueError if any argument \n",
    "is zero or negative. Apply it to safe_sqrt(x).\n",
    "    \n",
    "import math\n",
    "\n",
    "def validate_positive(func):\n",
    "    def wrapper(x):\n",
    "        if x <= 0:\n",
    "            raise ValueError(\"Argument must be positive\")\n",
    "        return func(x)\n",
    "    return wrapper\n",
    "\n",
    "\n",
    "@validate_positive\n",
    "def safe_sqrt(x):\n",
    "    return math.sqrt(x)\n",
    "\n",
