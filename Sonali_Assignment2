    "Section A:-Strings\n",
    "#1.write a function analyze_sentence(sentence) that takes a sentence and returns a dictionary with word_count,\n",
    "#char_count(excluding spaces).unique_words(case insensitive),and most_frequent_word text it with.\n",
    "\"The quick brown fox jumps over the lazy dog\"\n",
    "def analyze_sentence(sentence):\n",
    "    words = sentence.lower().split()\n",
    "\n",
    "    word_count = len(words)\n",
    "    char_count = len(sentence.replace(\" \", \"\"))\n",
    "    unique_words = len(set(words))\n",
    "\n",
    "    freq = {}\n",
    "    for word in words:\n",
    "        freq[word] = freq.get(word, 0) + 1\n",
    "\n",
    "    most_frequent_word = max(freq, key=freq.get)\n",
    "\n",
    "    return {\n",
    "        \"word_count\": word_count,\n",
    "        \"char_count\": char_count,\n",
    "        \"unique_words\": unique_words,\n",
    "        \"most_frequent_word\": most_frequent_word\n",
    "    }\n",
    "\n",
    "\n",
    "sentence = \"The quick brown fox jumps over the lazy dog the fox\"\n",
    "print(analyze_sentence(sentence))\n",
    "{'word_count': 11, 'char_count': 41, 'unique_words': 8, 'most_frequent_word': 'the'}"
   ]
